---
// src/components/Destaques.astro

// Uma listinha de dados simples para gerar os cards automaticamente (igual faríamos com um banco de dados depois)
const cards = [
  {
    titulo: "Eventos",
    descricao: "Fique por dentro das exposições, congressos e festejos da cultura popular.",
    link: "/eventos",
    cor: "bg-[#0B5D3F]", // Verde
  },
  {
    titulo: "Publicações",
    descricao: "Acesse nosso acervo digital de livros, artigos, cordéis e pesquisas históricas.",
    link: "/publicacoes",
    cor: "bg-[#D4A373]", // Terracota
  },
  {
    titulo: "Mestres da Cultura",
    descricao: "Conheça os guardiões da tradição popular e suas ricas contribuições.",
    link: "/mestres",
    cor: "bg-[#4A2E15]", // Marrom escuro
  }
];
---

<section class="max-w-6xl mx-auto px-4 py-20 relative z-10">
  
  <div class="text-center mb-16">
    <h2 class="text-4xl font-serif font-bold text-[#4A2E15] mb-4">Nossa Atuação</h2>
    <p class="text-lg text-[#4A2E15]/80 max-w-2xl mx-auto">
      Descubra como a Comissão trabalha para manter viva a memória e a diversidade do nosso estado.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    
    {cards.map((card) => (
      <a href={card.link} class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-2 border border-[#4A2E15]/5 flex flex-col justify-between h-full">
        
        <div>
          <div class={`w-12 h-2 rounded-full mb-6 ${card.cor}`}></div>
          <h3 class="text-2xl font-serif font-bold text-[#4A2E15] mb-4 group-hover:text-[#0B5D3F] transition-colors">
            {card.titulo}
          </h3>
          <p class="text-[#4A2E15]/70 leading-relaxed mb-8">
            {card.descricao}
          </p>
        </div>
        
        <div class="text-[#0B5D3F] font-bold text-sm tracking-wider uppercase flex items-center gap-2">
          Acessar <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
        </div>

      </a>
    ))}

  </div>
</section>