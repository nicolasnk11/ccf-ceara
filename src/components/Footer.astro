---
// src/components/Footer.astro
const anoAtual = new Date().getFullYear(); 
---

<footer class="bg-[#4A2E15] text-[#FDF8EE] pt-20 pb-10 mt-12 relative z-10 border-t-[6px] border-[#D4A373] font-['Poppins']">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16 mb-16">
      
      <div class="md:col-span-5">
        <div class="flex items-center gap-4 mb-6">
          <img src="/logoccf.jpg" alt="Logo CCF" class="h-14 w-14 object-contain mix-blend-screen grayscale contrast-200 brightness-150" />
          <div>
            <h3 class="font-bold text-lg tracking-widest leading-none text-[#FDF8EE]">COMISSÃO CEARENSE</h3>
            <span class="text-[11px] font-medium tracking-[0.3em] text-[#D4A373]">DE FOLCLORE</span>
          </div>
        </div>
        <p class="text-[#FDF8EE]/70 text-sm leading-relaxed max-w-sm font-light">
          Nascida em 1948, trabalhamos na pesquisa, registro e difusão das manifestações culturais, mantendo viva a memória e a tradição popular do Ceará.
        </p>
      </div>

      <div class="md:col-span-3 lg:pl-8">
        <h4 class="font-bold text-[#D4A373] mb-6 uppercase tracking-widest text-xs">Acervo e Pesquisa</h4>
        <ul class="space-y-4 text-sm text-[#FDF8EE]/80 font-light">
          <li><a href="/sobre" class="hover:text-[#D4A373] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[#0B5D3F] rounded-full"></span> Nossa História</a></li>
          <li><a href="/publicacoes" class="hover:text-[#D4A373] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[#0B5D3F] rounded-full"></span> Publicações</a></li>
          <li><a href="/eventos" class="hover:text-[#D4A373] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[#0B5D3F] rounded-full"></span> Agenda de Eventos</a></li>
          <li><a href="/mestres" class="hover:text-[#D4A373] transition-colors flex items-center gap-2"><span class="w-1.5 h-1.5 bg-[#0B5D3F] rounded-full"></span> Mestres da Cultura</a></li>
        </ul>
      </div>

      <div class="md:col-span-4">
        <h4 class="font-bold text-[#D4A373] mb-6 uppercase tracking-widest text-xs">Fale Conosco</h4>
        <ul class="space-y-4 text-sm text-[#FDF8EE]/80 font-light mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#0B5D3F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            contato@folclorecearense.org.br
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#0B5D3F] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            Fortaleza, Ceará - Brasil
          </li>
        </ul>
        
        <a href="/contato" class="inline-block border border-[#D4A373] text-[#D4A373] hover:bg-[#D4A373] hover:text-[#4A2E15] transition-all duration-300 px-6 py-2 text-xs tracking-widest uppercase font-bold">
          Enviar Mensagem
        </a>
      </div>

    </div>

    <div class="border-t border-[#FDF8EE]/10 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-[#FDF8EE]/50 gap-4 font-light">
      <p>&copy; {anoAtual} Comissão Cearense de Folclore. Patrimônio Imaterial.</p>
      
      <p class="flex items-center gap-1.5">
        Design & Código por <span class="font-medium text-[#D4A373] tracking-[0.15em] uppercase">Nicolas Castro</span>
      </p>
    </div>

  </div>
</footer>