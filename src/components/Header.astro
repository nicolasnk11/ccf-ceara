---
// src/components/Header.astro
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');
</style>

<header class="w-full bg-white shadow-sm sticky top-0 z-50 border-b border-[#D4A373]/30 font-['Poppins'] transition-all duration-300">
  
  <div class="h-1.5 w-full bg-[#0B5D3F]"></div>

  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-3 flex justify-between items-center relative">
    
    <a href="/" class="flex items-center gap-3 group z-20">
      <img src="/logoccf.jpg" alt="Logo CCF" class="h-11 w-11 object-contain mix-blend-multiply group-hover:scale-105 transition-transform duration-300" />
      <div class="flex flex-col">
        <span class="text-[13px] font-bold tracking-widest leading-none text-[#4A2E15] group-hover:text-[#0B5D3F] transition-colors">COMISSÃO CEARENSE</span>
        <span class="text-[10px] font-medium tracking-[0.2em] text-[#4A2E15]/70 mt-1">DE FOLCLORE</span>
      </div>
    </a>

    <nav class="hidden md:flex gap-8 items-center text-[15px] font-medium">
      <a href="/sobre" class="text-[#4A2E15] hover:text-[#0B5D3F] transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-[2px] after:bg-[#0B5D3F] hover:after:w-full after:transition-all after:duration-300">Sobre</a>
      <a href="/publicacoes" class="text-[#4A2E15] hover:text-[#0B5D3F] transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-[2px] after:bg-[#0B5D3F] hover:after:w-full after:transition-all after:duration-300">Publicações</a>
      <a href="/eventos" class="text-[#4A2E15] hover:text-[#0B5D3F] transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-[2px] after:bg-[#0B5D3F] hover:after:w-full after:transition-all after:duration-300">Eventos</a>
      <a href="/mestres" class="text-[#4A2E15] hover:text-[#0B5D3F] transition-colors relative after:content-[''] after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-[2px] after:bg-[#0B5D3F] hover:after:w-full after:transition-all after:duration-300">Mestres</a>

      <a href="/contato" class="ml-4 bg-[#FDF8EE] text-[#0B5D3F] border-2 border-[#4A2E15] shadow-[4px_4px_0px_#D4A373] hover:shadow-[6px_6px_0px_#0B5D3F] hover:-translate-y-0.5 px-6 py-2 transition-all duration-300 text-xs tracking-[0.15em] uppercase font-bold">
        Contato
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-center w-8 h-8 space-y-1.5 z-20 group">
      <span class="block w-6 h-0.5 bg-[#4A2E15] transition-transform duration-300 origin-center"></span>
      <span class="block w-6 h-0.5 bg-[#4A2E15] transition-opacity duration-300"></span>
      <span class="block w-6 h-0.5 bg-[#4A2E15] transition-transform duration-300 origin-center"></span>
    </button>

  </div>

  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-white border-b border-[#D4A373]/30 shadow-lg md:hidden flex-col items-center py-6 gap-6 z-10 font-medium">
    <a href="/sobre" class="text-[#4A2E15] hover:text-[#0B5D3F] text-lg">Sobre</a>
    <a href="/publicacoes" class="text-[#4A2E15] hover:text-[#0B5D3F] text-lg">Publicações</a>
    <a href="/eventos" class="text-[#4A2E15] hover:text-[#0B5D3F] text-lg">Eventos</a>
    <a href="/mestres" class="text-[#4A2E15] hover:text-[#0B5D3F] text-lg">Mestres</a>
    <a href="/contato" class="bg-[#FDF8EE] text-[#0B5D3F] border-2 border-[#4A2E15] shadow-[4px_4px_0px_#D4A373] px-8 py-2.5 mt-2 text-sm tracking-widest uppercase font-bold">
      Contato
    </a>
  </div>

</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const spans = menuToggle?.querySelectorAll('span');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
    
    // Animação simples do ícone hambúrguer virando um "X"
    if (mobileMenu?.classList.contains('flex') && spans) {
      spans[0].style.transform = 'translateY(8px) rotate(45deg)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'translateY(-8px) rotate(-45deg)';
    } else if (spans) {
      spans[0].style.transform = 'none';
      spans[1].style.opacity = '1';
      spans[2].style.transform = 'none';
    }
  });
</script>