---
// src/pages/mestres.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// 1. Importamos a função do Astro que lê os arquivos da pasta content
import { getCollection } from 'astro:content';

// 2. Pedimos ao Astro para buscar todos os Mestres cadastrados no painel
const mestres = await getCollection('mestres');
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mestres da Cultura | CCF</title>
  </head>
  <body class="bg-[#FDF8EE] text-[#4A2E15] min-h-screen font-sans flex flex-col relative overflow-x-hidden">
    
    <div class="absolute inset-0 pointer-events-none opacity-5 mix-blend-multiply z-0" 
         style="background-image: url('/textura-danca.jpg'); background-size: 600px; background-repeat: repeat;">
    </div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />
      
      <main class="flex-grow max-w-6xl mx-auto px-4 py-20 w-full">
        
        <div class="mb-24 text-center">
          <span class="text-[#0B5D3F] font-bold tracking-[0.3em] uppercase text-xs mb-3 block">Nossos Guardiões</span>
          <h1 class="text-5xl lg:text-6xl font-bold text-[#4A2E15] mb-6 tracking-tight">Mestres da Cultura</h1>
          <div class="w-20 h-2 bg-[#D4A373] mx-auto mb-8"></div>
          <p class="text-lg text-[#4A2E15]/80 max-w-2xl mx-auto font-light leading-relaxed">
            Bibliotecas vivas dos saberes e fazeres tradicionais do Ceará. Conheça as mãos e as vozes que mantêm a nossa história pulsando.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-20">
          
          {/* 3. Renderizamos os cards dinamicamente baseados nos dados do CMS */}
          {mestres.map((mestre) => (
            
            <div class="relative bg-white p-6 border-2 border-[#4A2E15] shadow-[8px_8px_0px_#D4A373] flex flex-col items-center text-center hover:-translate-y-2 hover:shadow-[12px_12px_0px_#0B5D3F] transition-all duration-500 group">
              
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-16 h-6 bg-[#FDF8EE] border border-[#D4A373]/30 shadow-sm -rotate-2 z-10 mix-blend-multiply"></div>
              
              <div class="w-full aspect-[3/4] border-2 border-[#4A2E15] mb-6 bg-stone-200 overflow-hidden relative">
                <img 
                  src={mestre.data.foto} 
                  alt={`Retrato de ${mestre.data.title}`} 
                  class="w-full h-full object-cover grayscale contrast-125 sepia-[.30] group-hover:grayscale-0 group-hover:sepia-0 group-hover:scale-110 transition-all duration-700" 
                />
              </div>

              <h2 class="text-2xl font-bold text-[#4A2E15] mb-2 leading-tight">
                {mestre.data.title}
              </h2>
              
              <p class="text-[#0B5D3F] font-bold tracking-widest uppercase text-xs mb-5">
                {mestre.data.atuacao}
              </p>
              
              <div class="flex gap-1.5 mb-5">
                <div class="w-2 h-2 bg-[#D4A373] rotate-45 group-hover:bg-[#0B5D3F] transition-colors duration-300"></div>
                <div class="w-2 h-2 bg-[#D4A373] rotate-45 group-hover:bg-[#0B5D3F] transition-colors duration-300 delay-75"></div>
                <div class="w-2 h-2 bg-[#D4A373] rotate-45 group-hover:bg-[#0B5D3F] transition-colors duration-300 delay-150"></div>
              </div>
              
              <p class="text-[#4A2E15]/70 text-sm font-light">
                {mestre.data.cidade}
              </p>

            </div>

          ))}
        </div>

      </main>

      <Footer />
    </div>

  </body>
</html>