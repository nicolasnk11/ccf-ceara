---
// src/pages/contato.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Fale Conosco | CCF</title>
  </head>
  <body class="bg-[#FDF8EE] text-[#4A2E15] min-h-screen font-sans flex flex-col relative overflow-x-hidden">
    
    <div class="absolute inset-0 pointer-events-none opacity-5 mix-blend-multiply z-0" 
         style="background-image: url('/textura-danca.jpg'); background-size: 600px; background-repeat: repeat;">
    </div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />
      
      <main class="flex-grow max-w-6xl mx-auto px-4 py-20 lg:py-32 w-full">
        
        <div class="mb-20 text-center">
          <span class="text-[#0B5D3F] font-bold tracking-[0.3em] uppercase text-xs mb-3 block">Conexão</span>
          <h1 class="text-5xl lg:text-6xl font-bold text-[#4A2E15] mb-6 tracking-tight">Fale Conosco</h1>
          <div class="w-24 h-2 bg-[#D4A373] mx-auto"></div>
          <p class="text-lg text-[#4A2E15]/80 max-w-2xl mx-auto mt-8 font-light">
            Tem alguma dúvida, sugestão de acervo ou quer firmar uma parceria? Nossas portas e caixas de entrada estão sempre abertas.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">
          
          <div class="space-y-12">
            
            <div>
              <h2 class="text-3xl font-bold text-[#4A2E15] tracking-tight mb-4">Estamos aqui.</h2>
              <p class="text-[#4A2E15]/80 text-lg font-light leading-relaxed">
                A Comissão Cearense de Folclore é feita por pessoas e para pessoas. Se você é estudante, pesquisador, mestre da cultura ou apenas um apaixonado pela nossa história, adoraríamos ouvir você.
              </p>
            </div>

            <div class="space-y-8">
              <div class="flex items-start gap-4 group">
                <div class="w-12 h-12 bg-white border-2 border-[#4A2E15] shadow-[4px_4px_0px_#D4A373] flex items-center justify-center text-[#0B5D3F] group-hover:bg-[#0B5D3F] group-hover:text-white transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-[#4A2E15] uppercase tracking-widest text-xs mb-1">E-mail</h4>
                  <a href="mailto:contato@folclorecearense.org.br" class="text-[#4A2E15]/80 font-medium hover:text-[#0B5D3F] transition-colors">contato@folclorecearense.org.br</a>
                </div>
              </div>

              <div class="flex items-start gap-4 group">
                <div class="w-12 h-12 bg-white border-2 border-[#4A2E15] shadow-[4px_4px_0px_#D4A373] flex items-center justify-center text-[#0B5D3F] group-hover:bg-[#0B5D3F] group-hover:text-white transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-[#4A2E15] uppercase tracking-widest text-xs mb-1">Sede / Arquivo</h4>
                  <p class="text-[#4A2E15]/80 font-medium">Fortaleza, Ceará - Brasil <br/> <span class="text-sm font-light italic">(Atendimento presencial mediante agendamento)</span></p>
                </div>
              </div>
            </div>

            <div class="pt-8 border-t border-[#4A2E15]/10">
              <h4 class="font-bold text-[#4A2E15] uppercase tracking-widest text-xs mb-4">Acompanhe a CCF</h4>
              <div class="flex gap-4">
                <a href="#" class="w-10 h-10 bg-[#4A2E15] text-[#FDF8EE] hover:bg-[#0B5D3F] transition-colors flex items-center justify-center rounded-full">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm3.98-10.181a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.88z"/></svg>
                </a>
                <a href="#" class="w-10 h-10 bg-[#4A2E15] text-[#FDF8EE] hover:bg-[#0B5D3F] transition-colors flex items-center justify-center rounded-full">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              </div>
            </div>

          </div>

          <div class="bg-white p-8 md:p-12 border-2 border-[#4A2E15] shadow-[12px_12px_0px_#D4A373] relative">
            
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-20 h-8 bg-[#FDF8EE] border border-[#D4A373]/30 shadow-sm -rotate-2 mix-blend-multiply z-10"></div>
            
            <h3 class="text-2xl font-bold text-[#4A2E15] mb-8 tracking-tight">Envie uma mensagem</h3>
            
            <form class="space-y-6">
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                  <label for="nome" class="text-xs font-bold text-[#4A2E15] uppercase tracking-widest">Seu Nome</label>
                  <input type="text" id="nome" class="w-full bg-[#FDF8EE] border-2 border-[#4A2E15] px-4 py-3 text-[#4A2E15] focus:outline-none focus:border-[#0B5D3F] focus:ring-0 transition-colors" placeholder="Maria da Silva" required />
                </div>
                
                <div class="space-y-2">
                  <label for="email" class="text-xs font-bold text-[#4A2E15] uppercase tracking-widest">Seu E-mail</label>
                  <input type="email" id="email" class="w-full bg-[#FDF8EE] border-2 border-[#4A2E15] px-4 py-3 text-[#4A2E15] focus:outline-none focus:border-[#0B5D3F] focus:ring-0 transition-colors" placeholder="maria@email.com" required />
                </div>
              </div>

              <div class="space-y-2">
                <label for="assunto" class="text-xs font-bold text-[#4A2E15] uppercase tracking-widest">Assunto</label>
                <select id="assunto" class="w-full bg-[#FDF8EE] border-2 border-[#4A2E15] px-4 py-3 text-[#4A2E15] focus:outline-none focus:border-[#0B5D3F] focus:ring-0 transition-colors cursor-pointer">
                  <option value="">Selecione o motivo do contato...</option>
                  <option value="pesquisa">Pesquisa Acadêmica / Acervo</option>
                  <option value="evento">Convite para Eventos</option>
                  <option value="duvida">Dúvidas Gerais</option>
                  <option value="outro">Outros Assuntos</option>
                </select>
              </div>

              <div class="space-y-2">
                <label for="mensagem" class="text-xs font-bold text-[#4A2E15] uppercase tracking-widest">Sua Mensagem</label>
                <textarea id="mensagem" rows="5" class="w-full bg-[#FDF8EE] border-2 border-[#4A2E15] px-4 py-3 text-[#4A2E15] focus:outline-none focus:border-[#0B5D3F] focus:ring-0 transition-colors resize-none" placeholder="Escreva sua mensagem aqui..." required></textarea>
              </div>

              <button type="submit" class="w-full bg-[#0B5D3F] text-white border-2 border-[#4A2E15] font-bold uppercase tracking-widest py-4 mt-4 shadow-[6px_6px_0px_#4A2E15] hover:shadow-[2px_2px_0px_#4A2E15] hover:translate-y-1 hover:translate-x-1 transition-all active:shadow-none active:translate-y-2 active:translate-x-2">
                Enviar Mensagem
              </button>
              
            </form>

          </div>

        </div>

      </main>

      <Footer />
    </div>
  </body>
</html>