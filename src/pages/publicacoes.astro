---
// src/pages/publicacoes.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// 1. Importa a função mágica do Astro
import { getCollection } from 'astro:content';

// 2. Busca dinamicamente todas as publicações cadastradas no CMS
const publicacoes = await getCollection('publicacoes');
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Acervo de Publicações | CCF</title>
  </head>
  <body class="bg-[#FDF8EE] text-[#4A2E15] min-h-screen font-sans flex flex-col relative overflow-x-hidden">
    
    <div class="absolute inset-0 pointer-events-none opacity-5 mix-blend-multiply z-0" 
         style="background-image: url('/textura-danca.jpg'); background-size: 600px; background-repeat: repeat;">
    </div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <Header />
      
      <main class="flex-grow max-w-7xl mx-auto px-4 py-20 lg:py-24 w-full">
        
        <div class="mb-24 text-center">
          <span class="text-[#0B5D3F] font-bold tracking-[0.3em] uppercase text-xs mb-3 block">Biblioteca Digital</span>
          <h1 class="text-5xl lg:text-6xl font-bold text-[#4A2E15] mb-6 tracking-tight">Acervo de Publicações</h1>
          <div class="w-20 h-2 bg-[#D4A373] mx-auto mb-8"></div>
          <p class="text-lg text-[#4A2E15]/80 max-w-2xl mx-auto font-light leading-relaxed">
            O registro documental da nossa memória. Explore livros, cordéis, artigos e catálogos sobre a cultura popular.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-10 gap-y-16">
          
          {/* 3. Renderiza os dados lidos do CMS */}
          {publicacoes.map((pub) => (
            
            <a href="#" class="group flex flex-col cursor-pointer">
              
              <div class="w-full aspect-[2/3] bg-white border-2 border-[#4A2E15] shadow-[6px_6px_0px_#D4A373] mb-6 overflow-hidden relative transition-all duration-500 group-hover:-translate-y-2 group-hover:shadow-[10px_10px_0px_#0B5D3F]">
                
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-12 h-6 bg-[#FDF8EE] border border-[#D4A373]/30 shadow-sm -rotate-3 z-10 mix-blend-multiply"></div>
                
                <img 
                  src={pub.data.capa} 
                  alt={`Capa de ${pub.data.title}`} 
                  class="w-full h-full object-cover grayscale contrast-125 sepia-[.25] transition-all duration-700 group-hover:grayscale-0 group-hover:sepia-0 group-hover:scale-110" 
                />
              </div>

              <span class="text-[#0B5D3F] text-[10px] font-bold uppercase tracking-[0.2em] mb-2">
                {pub.data.tipo}
              </span>
              
              <h3 class="text-xl font-bold text-[#4A2E15] leading-snug mb-2 group-hover:text-[#0B5D3F] transition-colors">
                {pub.data.title}
              </h3>
              
              <p class="text-sm text-[#4A2E15]/70 font-light flex items-center gap-2">
                {pub.data.autor} <span class="text-[#D4A373] font-bold">•</span> {pub.data.ano}
              </p>
              
            </a>

          ))}
          
        </div>

      </main>

      <Footer />
    </div>

  </body>
</html>