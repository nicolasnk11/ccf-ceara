---
// src/pages/index.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Destaques from '../components/Destaques.astro';
import Footer from '../components/Footer.astro';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Comissão Cearense de Folclore</title>
  </head>
  <body class="bg-[#FDF8EE] text-[#4A2E15] min-h-screen font-sans overflow-x-hidden">
    
    <Header />
    
    <main>
      <Hero />
      
      <div class="w-full h-72 md:h-96 opacity-15 mix-blend-multiply bg-fixed pointer-events-none" 
           style="background-image: url('/textura-danca.jpg'); 
                  background-size: 1980px; 
                  background-repeat: repeat; 
                  background-position: center;">
      </div>
      
      <Destaques />
    </main>

    <Footer />

  </body>
</html>